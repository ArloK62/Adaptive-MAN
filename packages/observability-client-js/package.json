{
  "name": "@adaptive/observability-client-js",
  "version": "0.1.0",
  "description": "Adaptive Observability frontend SDK. API surface mirrors SCH's analytics.ts so PostHog migration is import-line-only.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./axios": {
      "types": "./dist/axios.d.ts",
      "import": "./dist/axios.js",
      "require": "./dist/axios.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./replay": {
      "types": "./dist/replay.d.ts",
      "import": "./dist/replay.js",
      "require": "./dist/replay.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "axios": ">=1.0.0",
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "axios": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "axios": "^1.7.7",
    "react": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
